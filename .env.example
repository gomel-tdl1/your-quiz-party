# Скопируй в .env.local и подставь значения из своего проекта Supabase.

# 1) Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# 2) Settings → Database → Connection string → URI
#    Нужна для АВТОМАТИЧЕСКОЙ миграции при `npm run dev` (создаёт таблицы).
#    Подставь пароль базы вместо [YOUR-PASSWORD].
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
